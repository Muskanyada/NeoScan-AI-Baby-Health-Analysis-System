  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Hyperparameters ──────────────────────────────────────────────\n",
    "IMG_SIZE    = 224\n",
    "BATCH_SIZE  = 32\n",
    "EPOCHS      = 30\n",
    "LR          = 1e-4\n",
    "MIN_LR      = 1e-6\n",
    "WEIGHT_DECAY = 1e-4\n",
    "NUM_WORKERS  = 2\n",
    "PATIENCE     = 7          # early stopping\n",
    "LABEL_SMOOTH = 0.1\n",
    "\n",
    "# ── Class mapping: folder paths → unified class name ─────────────\n",
    "CLASS_MAP = {\n",
    "    # normal\n",
    "    'datasets/normal'          : 'normal',\n",
    "    'dataset/1_normal'         : 'normal',\n",
    "    'image/Normal'             : 'rop_normal',\n",
    "    # cataract\n",
    "    'datasets/cataract'        : 'cataract',\n",
    "    'dataset/2_cataract'       : 'cataract',\n",
    "    # glaucoma\n",
    "    'datasets/glaucoma'        : 'glaucoma',\n",
    "    'dataset/2_glaucoma'       : 'glaucoma',\n",
    "    # diabetic retinopathy\n",
    "    'datasets/diabetes'        : 'diabetic_retinopathy',\n",
    "    # AMD\n",
    "    'datasets/ageDegeneration' : 'age_macular_degeneration',\n",
    "    # hypertension\n",
    "    'datasets/hypertension'    : 'hypertension',\n",
    "    # myopia\n",
    "    'datasets/myopia'          : 'myopia',\n",
    "    # other retina\n",
    "    'datasets/others'          : 'other_retina',\n",
    "    'dataset/3_retina_disease' : 'other_retina',\n",
    "    # ROP disease (stages + laser scars grouped)\n",
    "    'image/Stage1'             : 'rop_disease',\n",
    "    'image/Stage2'             : 'rop_disease',\n",
    "    'image/Stage3'             : 'rop_disease',\n",
    "    'image/laser scars'        : 'rop_disease',\n",
    "}\n",
    "\n",
    "VALID_EXTENSIONS = {'.jpg', '.jpeg', '.png', '.tif', '.tiff', '.bmp'}\n",
    "\n",
    "print('Class mapping loaded:')\n",
    "classes_set = sorted(set(CLASS_MAP.values()))\n",
    "CLASS2IDX = {c: i for i, c in enumerate(classes_set)}\n",
    "IDX2CLASS  = {i: c for c, i in CLASS2IDX.items()}\n",
    "NUM_CLASSES = len(CLASS2IDX)\n",
    "\n",
    "for i, c in IDX2CLASS.items():\n",
    "    print(f'  [{i}] {c}')\n",
    "print(f'\\nTotal classes: {NUM_CLASSES}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 5 — Build Master Dataframe"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "records = []\n",
    "\n",
    "for rel_folder, class_name in CLASS_MAP.items():\n",
    "    abs_folder = os.path.join(ROOT, rel_folder)\n",
    "    if not os.path.isdir(abs_folder):\n",
    "        print(f'⚠️  Not found: {abs_folder}')\n",
    "        continue\n",
    "    for fname in os.listdir(abs_folder):\n",
    "        ext = Path(fname).suffix.lower()\n",
    "        if ext in VALID_EXTENSIONS:\n",
    "            records.append({\n",
    "                'path'      : os.path.join(abs_folder, fname),\n",
    "                'class_name': class_name,\n",
    "                'label'     : CLASS2IDX[class_name],\n",
    "                'source'    : rel_folder,\n",
    "            })\n",
    "\n",
    "df = pd.DataFrame(records)\n",
    "print(f'Total images collected: {len(df)}')\n",
    "print()\n",
    "print('Per-class counts:')\n",
    "counts = df['class_name'].value_counts().sort_index()\n",
    "for cls, cnt in counts.items():\n",
    "    bar = '█' * (cnt // 100)\n",
    "    print(f'  {cls:<30s} {cnt:5d}  {bar}')"
