   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 13 — Load Best Model & Run Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "checkpoint = torch.load(BEST_PATH, map_location=DEVICE)\n",
    "model.load_state_dict(checkpoint['model_state_dict'])\n",
    "print(f\"Loaded best model from epoch {checkpoint['epoch']} (val_acc={checkpoint['val_acc']:.4f})\")\n",
    "\n",
    "_, test_acc, test_preds, test_labels, test_probs = evaluate(model, test_loader, criterion, DEVICE)\n",
    "test_f1  = f1_score(test_labels, test_preds, average='weighted')\n",
    "\n",
    "# AUC (one-vs-rest)\n",
    "try:\n",
    "    test_auc = roc_auc_score(\n",
    "        label_binarize(test_labels, classes=list(range(NUM_CLASSES))),\n",
    "        test_probs, multi_class='ovr', average='weighted'\n",
    "    )\n",
    "except:\n",
    "    test_auc = float('nan')\n",
    "\n",
    "print(f'\\n📊 TEST RESULTS')\n",
    "print(f'  Accuracy        : {test_acc*100:.2f}%')\n",
    "print(f'  Weighted F1     : {test_f1:.4f}')\n",
    "print(f'  Weighted AUC-ROC: {test_auc:.4f}')"
