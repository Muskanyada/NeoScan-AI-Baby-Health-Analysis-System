   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 18 — Grad-CAM Visualizations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Target layer for EfficientNet-B4 (last conv block)\n",
    "target_layer = model.backbone.blocks[-1]\n",
    "cam = GradCAM(model=model, target_layers=[target_layer])\n",
    "\n",
    "def denormalize(tensor):\n",
    "    mean = np.array([0.485, 0.456, 0.406])\n",
    "    std  = np.array([0.229, 0.224, 0.225])\n",
    "    img  = tensor.permute(1, 2, 0).cpu().numpy()\n",
    "    img  = std * img + mean\n",
    "    return np.clip(img, 0, 1).astype(np.float32)\n",
    "\n",
    "\n",
    "def visualize_gradcam(model, dataset_df, transform, n_per_class=2):\n",
    "    \"\"\"\n",
    "    Show Grad-CAM for n_per_class samples per class.\n",
    "    Returns a matplotlib figure.\n",
    "    \"\"\"\n",
    "    model.eval()\n",
    "    n_cols  = n_per_class * 2   # orig + cam\n",
    "    n_rows  = NUM_CLASSES\n",
    "    fig, axes = plt.subplots(n_rows, n_cols, figsize=(n_cols * 2.5, n_rows * 2.5))\n",
    "\n",
    "    for cls_idx in range(NUM_CLASSES):\n",
    "        cls_name = IDX2CLASS[cls_idx]\n",
    "        cls_rows = dataset_df[dataset_df['label'] == cls_idx]\n",
    "        samples  = cls_rows.sample(min(n_per_class, len(cls_rows)), random_state=SEED)\n",
    "\n",
    "        for col_i, (_, row) in enumerate(samples.iterrows()):\n",
    "            try:\n",
    "                img_np = cv2.cvtColor(cv2.imread(row['path']), cv2.COLOR_BGR2RGB)\n",
    "            except:\n",
    "                img_np = np.zeros((IMG_SIZE, IMG_SIZE, 3), dtype=np.uint8)\n",
    "\n",
    "            aug    = transform(image=img_np)['image'].unsqueeze(0).to(DEVICE)\n",
    "            orig   = denormalize(aug.squeeze(0))\n",
    "            target = [ClassifierOutputTarget(cls_idx)]\n",
    "            grayscale_cam = cam(input_tensor=aug, targets=target)[0]\n",
    "            cam_img = show_cam_on_image(orig, grayscale_cam, use_rgb=True)\n",
    "\n",
    "            # Original image\n",
    "            ax_orig = axes[cls_idx][col_i * 2]\n",
    "            ax_orig.imshow(orig)\n",
    "            ax_orig.axis('off')\n",
    "            if col_i == 0:\n",
    "                ax_orig.set_ylabel(cls_name, fontsize=8, fontweight='bold', rotation=0,\n",
    "                                   labelpad=60, va='center')\n",
    "\n",
    "            # Grad-CAM overlay\n",
    "            ax_cam = axes[cls_idx][col_i * 2 + 1]\n",
    "            ax_cam.imshow(cam_img)\n",
    "            ax_cam.axis('off')\n",
    "            if cls_idx == 0:\n",
    "                ax_orig.set_title('Original', fontsize=8)\n",
    "                ax_cam.set_title('Grad-CAM', fontsize=8)\n",
    "\n",
    "    plt.suptitle('Grad-CAM Visualizations — EfficientNet-B4', fontsize=14, fontweight='bold')\n",
    "    plt.tight_layout()\n",
    "    return fig\n",
    "\n",
    "\n",
    "fig_cam = visualize_gradcam(model, test_df, val_transform, n_per_class=2)\n",
    "fig_cam.savefig(f'{OUTPUT_DIR}/gradcam_visualizations.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Saved: gradcam_visualizations.png')"
   ]
