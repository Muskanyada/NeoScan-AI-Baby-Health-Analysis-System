  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "test_df_results = test_df.copy()\n",
    "test_df_results['pred_label']     = test_preds\n",
    "test_df_results['pred_class']     = [IDX2CLASS[p] for p in test_preds]\n",
    "test_df_results['true_class']     = [IDX2CLASS[l] for l in test_labels]\n",
    "test_df_results['confidence']     = test_probs.max(axis=1)\n",
    "test_df_results['correct']        = test_preds == test_labels\n",
    "\n",
    "# Add probabilities for each class\n",
    "for i, cn in enumerate(class_names):\n",
    "    test_df_results[f'prob_{cn}'] = test_probs[:, i]\n",
    "\n",
    "# Misclassified\n",
    "wrong_df = test_df_results[~test_df_results['correct']].copy()\n",
    "print(f'Misclassified: {len(wrong_df)} / {len(test_df_results)} ({len(wrong_df)/len(test_df_results)*100:.1f}%)')\n",
    "\n",
    "# Top confusion pairs\n",
    "print('\\nTop confusion pairs (true → pred):')\n",
    "pairs = wrong_df.groupby(['true_class', 'pred_class']).size().sort_values(ascending=False).head(15)\n",
    "for (t, p), cnt in pairs.items():\n",
    "    print(f'  {t:30s} → {p:30s} : {cnt}')\n",
    "\n",
    "# Save full predictions\n",
    "test_df_results.to_csv(f'{OUTPUT_DIR}/test_predictions.csv', index=False)\n",
    "wrong_df.to_csv(f'{OUTPUT_DIR}/misclassified_samples.csv', index=False)\n",
    "print('\\nSaved: test_predictions.csv')\n",
    "print('Saved: misclassified_samples.csv')"
   ]
